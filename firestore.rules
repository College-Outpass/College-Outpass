rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email.toLower() == 'srinivasnaidu.m@srichaitanyaschool.net' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isPrincipal() {
      let email = request.auth.token.email.toLower();
      return isAdmin() || 
             email == 'pucneetboysprincipal@srichaitanyacollege.net' ||
             email == 'ecitypucprincipal2@srichaitanyacollege.net' ||
             email == 'ecitypucprincipal1@srichaitanyacollege.net' ||
             email == 'electroniccityprincipal@srichaitanyaschool.net';
    }
    
    // Core Collections
    match /outpasses/{id} {
      allow read, write: if isAuthenticated();
      allow delete: if isPrincipal();
    }
    
    match /mediSlips/{id} {
      allow read, write: if isAuthenticated();
      allow delete: if isPrincipal();
    }

    match /sickSlips/{id} {
      allow read, write: if isAuthenticated();
      allow delete: if isPrincipal();
    }

    match /students/{id} {
      allow read: if isAuthenticated();
      allow write: if isPrincipal();
    }

    // Profiles
    match /staff/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
    
    match /settings/{id} {
      allow read, write: if isAuthenticated();
    }

    match /security/{id} {
      allow read, write: if isAuthenticated();
    }

    // Default: Deny other access
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}

